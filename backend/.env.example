# PostgreSQL connection string from your managed database
# (Render Postgres, Railway Postgres, Supabase, Neon, etc.)
# Example: postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./bus_system.db

# Exact URL of your deployed frontend (Vercel), used for CORS.
# Leave as * only for local development.
FRONTEND_ORIGIN=*
